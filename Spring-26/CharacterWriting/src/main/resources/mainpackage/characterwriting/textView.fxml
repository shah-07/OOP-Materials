<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="mainPane" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="mainpackage.characterwriting.TextViewController">
   <children>
      <TextField fx:id="modelTF" layoutX="60.0" layoutY="53.0" promptText="Model" />
      <Button layoutX="60.0" layoutY="187.0" mnemonicParsing="false" onAction="#addButtonOA" text="Add Object" />
      <Button layoutX="521.0" layoutY="350.0" mnemonicParsing="false" onAction="#nextPageButtonOA" text="Next" />
      <TextField fx:id="engineNumberTF" layoutX="272.0" layoutY="53.0" promptText="EngineNumber" />
      <TextField fx:id="licenceNumTF" layoutX="60.0" layoutY="116.0" promptText="Licence" />
      <TextField fx:id="stringTF" layoutX="380.0" layoutY="142.0" />
      <Button layoutX="380.0" layoutY="200.0" mnemonicParsing="false" onAction="#addStringButtonOA" text="Add String" />
   </children>
</AnchorPane>
